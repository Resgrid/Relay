<ui:FluentWindow x:Class="Resgrid.Audio.Relay.ShellWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:tb="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
                 xmlns:views="clr-namespace:Resgrid.Audio.Relay.Views"
                 xmlns:conv="clr-namespace:Resgrid.Audio.Relay.Converters"
                 mc:Ignorable="d"
                 Title="Resgrid Relay"
                 Height="640" Width="1000"
                 MinHeight="480" MinWidth="760"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <ui:FluentWindow.Resources>
        <conv:RelayServiceStateToBrushConverter x:Key="StateBrush" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <ui:TitleBar Grid.Row="0"
                     Title="Resgrid Relay"
                     ShowMaximize="True"
                     ShowMinimize="True" />

        <!-- Navigation + content -->
        <ui:NavigationView x:Name="RootNavigation"
                           Grid.Row="1"
                           PaneDisplayMode="Left"
                           IsBackButtonVisible="Collapsed">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Dashboard"
                                       TargetPageType="{x:Type views:DashboardView}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Home24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Operations"
                                       TargetPageType="{x:Type views:OperationsView}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Play24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Configuration"
                                       TargetPageType="{x:Type views:ConfigurationView}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Settings24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Logs"
                                       TargetPageType="{x:Type views:LogsView}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="DocumentText24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Devices"
                                       TargetPageType="{x:Type views:DevicesView}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="UsbStick24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>
            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="About"
                                       TargetPageType="{x:Type views:AboutView}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Info24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>

        <!-- Footer status bar -->
        <Border Grid.Row="2"
                Padding="12,6"
                Background="#22000000">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Overall health traffic-light -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="12" Height="12" Margin="0,0,8,0"
                             Fill="{Binding OverallState, Converter={StaticResource StateBrush}}" />
                    <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Master Start/Stop -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ui:Button Content="Start"
                               Margin="0,0,8,0"
                               Command="{Binding StartCommand}" />
                    <ui:Button Content="Stop"
                               Command="{Binding StopCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tray icon -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="Resgrid Relay"
                        NoLeftClickDelay="True"
                        TrayLeftMouseUp="TrayIcon_OnTrayLeftMouseUp">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open" Click="TrayOpen_OnClick" />
                    <Separator />
                    <MenuItem Header="Quit" Click="TrayQuit_OnClick" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</ui:FluentWindow>
